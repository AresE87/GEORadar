# ==========================================
# GEORadar — Variables de Entorno
# ==========================================
# Copia este archivo como .env y rellena los valores

# --- Supabase ---
# URL de tu proyecto Supabase (se encuentra en Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co
# Clave anónima de Supabase (para el cliente público)
SUPABASE_ANON_KEY=tu-anon-key
# Clave de servicio de Supabase (solo para el servidor — nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- OpenAI ---
# Clave de API de OpenAI (para GPT-4o y gpt-4o-mini)
OPENAI_API_KEY=sk-tu-openai-key
# Modelo para análisis profundo (recomendaciones, auditorías detalladas)
OPENAI_ANALYSIS_MODEL=gpt-4o
# Modelo para queries masivos de monitoreo (más barato, ~10x menos costo)
OPENAI_QUERY_MODEL=gpt-4o-mini

# --- Anthropic ---
# Clave de API de Anthropic (para consultas cross-LLM)
ANTHROPIC_API_KEY=sk-ant-tu-anthropic-key
# Haiku es suficiente y más económico para queries de monitoreo
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Perplexity ---
# Clave de API de Perplexity (api.perplexity.ai)
PERPLEXITY_API_KEY=pplx-tu-perplexity-key
# Modelo sonar con acceso a búsqueda web en tiempo real
PERPLEXITY_MODEL=sonar

# --- Resend (Email) ---
# Clave de API de Resend para enviar alertas de visibilidad por email
RESEND_API_KEY=re_tu-resend-key
# Dirección de email remitente para alertas
RESEND_FROM_EMAIL=alerts@georadar.io

# --- Límites del Plan ---
# Cantidad de queries por marca por día en el plan Free
QUERIES_PER_BRAND_PER_DAY=5
# Máximo de marcas monitoreadas en plan Free
MAX_BRANDS_FREE=1
# Máximo de marcas monitoreadas en plan Pro
MAX_BRANDS_PRO=5

# --- Control de Concurrencia ---
# Límite de llamadas paralelas a LLMs (p-limit)
MAX_QUERIES_CONCURRENT=3

# --- Rate Limiting ---
# Requests por hora al audit tool público (por IP)
AUDIT_TOOL_RATE_LIMIT_HOUR=20
