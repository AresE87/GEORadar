---
import '../styles/global.css';
import AuditTool from '../components/AuditTool';
import SEO from '../components/SEO.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <SEO
      title="AI Brand Audit Gratis — ¿Cómo te describe ChatGPT?"
      description="Descubre tu visibilidad en IA en 60 segundos. Analiza cómo aparece tu marca en ChatGPT, Claude y Perplexity. Gratis, sin registro."
      path="/audit"
    />
  </head>
  <body class="min-h-screen bg-slate-50 dark:bg-slate-950">
    <!-- Header -->
    <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="4" />
            </svg>
          </div>
          <span class="font-bold text-lg text-slate-900 dark:text-white">GEORadar</span>
        </a>
        <a href="/dashboard" class="text-sm font-medium text-blue-600 hover:text-blue-700">
          Dashboard →
        </a>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-16">
      <!-- Hero -->
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white leading-tight">
          ¿Cómo te describe ChatGPT<br />cuando te buscan?
        </h1>
        <p class="mt-4 text-lg text-slate-500 max-w-xl mx-auto">
          Descubre tu visibilidad en IA en 60 segundos — gratis
        </p>
      </div>

      <!-- Audit tool -->
      <AuditTool client:load />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 dark:border-slate-800 py-8">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="text-sm text-slate-500">
          GEORadar — Monitorea tu visibilidad en ChatGPT, Claude y Perplexity
        </p>
      </div>
    </footer>
  </body>
</html>
